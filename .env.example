# Bias 환경변수 템플릿. 실제 값은 .env.local 에 채운다(.env.local 은 커밋 안 됨).
# cp .env.example .env.local  후 값 입력.

# ── Supabase (유저/프로필/구독 DB) ──
# lib/supabase.ts — 비어 있으면 프로필 조회/저장이 동작하지 않음.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Sui 네트워크 (지갑 로그인 서명 검증 / 결제) ──
# app/api/auth/wallet/route.ts — mainnet | testnet (미설정 시 mainnet)
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── 온체인 구독 결제 (lib/subscription.ts) ──
# 구독 Move 패키지 배포 후 주소 주입. 미설정 시 결제 트랜잭션 빌드 불가.
NEXT_PUBLIC_SUBSCRIPTION_PKG=
NEXT_PUBLIC_SUBSCRIPTION_TREASURY=

# ── AI 채팅 백엔드 (bias-chat, 별도 서비스) ──
# app/api/chat/* 가 프록시하는 업스트림. 미설정 시 127.0.0.1:5001.
BIAS_CHAT_BASE_URL=http://127.0.0.1:5001
